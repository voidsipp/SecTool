# ── SecTool configuration ───────────────────────────────────────────────────
# Copy this file to ".env" and fill in the values. All values shown are defaults
# unless marked REQUIRED.

# ── Discord ──────────────────────────────────────────────────────────────────
# REQUIRED. Create one under: Discord channel -> Edit Channel -> Integrations ->
# Webhooks -> New Webhook -> Copy Webhook URL.
DISCORD_WEBHOOK_URL=
# Optional override of the webhook's display name / avatar.
DISCORD_USERNAME=UDM Sentinel
#DISCORD_AVATAR_URL=
# Optional role/user to ping on critical+high alerts, e.g. <@&123> or <@123>.
#DISCORD_MENTION=

# ── Syslog listener ──────────────────────────────────────────────────────────
# Configure your UDM Pro to forward logs here:
#   UniFi -> Settings -> System -> Logging / Remote Logging (Syslog)
#   Host = this machine's LAN IP, Port = SYSLOG_UDP_PORT below, enable
#   "Include more detailed logs" / "Debug" so IDS/IPS events are exported.
SYSLOG_HOST=0.0.0.0
# 514 needs admin/root. 5514 works unprivileged — set the UDM to match.
SYSLOG_UDP_PORT=5514
SYSLOG_PROTOCOL=udp          # udp | tcp | both
SYSLOG_TCP_PORT=5514

# ── Claude (summarization) ───────────────────────────────────────────────────
# auto  -> use OAuth (~/.claude/.credentials.json) if present, else API key
# oauth -> force OAuth (your Claude Code / Max subscription)
# apikey-> force ANTHROPIC_API_KEY
CLAUDE_AUTH_MODE=auto
#ANTHROPIC_API_KEY=
# Leave blank to use the default credentials path (~/.claude/.credentials.json)
#CLAUDE_CREDENTIALS_PATH=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
SUMMARIZE_ENABLED=true       # false -> send raw alerts without Claude

# ── Correlation / log gathering ──────────────────────────────────────────────
# Recent log lines are buffered in memory so an alert can be enriched with the
# surrounding context (same source/destination IPs, same time window).
LOG_BUFFER_SIZE=5000         # max events held in the ring buffer
LOG_BUFFER_TTL_SEC=900       # drop buffered events older than this
CORRELATION_WINDOW_SEC=180   # look this far back/forward for related events
CORRELATION_MAX_EVENTS=40    # cap related events attached to an alert

# ── Alert handling ───────────────────────────────────────────────────────────
# Minimum severity to notify on: critical | high | medium | low | info
MIN_SEVERITY=low
# Suppress duplicate alerts (same signature + src/dst) for this many seconds.
DEDUPE_WINDOW_SEC=300
# If a detection was already blocked/dropped at the gateway, skip the
# notification (the threat was stopped at the edge — it's noise, not an action
# item). Such detections are still recorded to the dashboard history. Set to
# false to be notified about gateway-blocked detections too.
SKIP_GATEWAY_BLOCKED=true
# Optional custom regex (case-insensitive) that a log line MUST match to be
# treated as a security alert. Leave blank to use the built-in heuristics.
#ALERT_PATTERN=

# ── Historical backfill (node src/index.ts --backfill [hours]) ───────────────
# Only needed if you run the one-time backfill of past IDS/IPS events. The live
# syslog service does NOT use these. Use a LOCAL UniFi admin account (not your
# Ubiquiti SSO email). Create one under: UniFi OS -> Admins -> Add Admin ->
# "Restrict to local access only".
UNIFI_HOST=https://192.168.0.1
UNIFI_SITE=default
# Option A: local admin (works with the internal IDS/IPS event endpoint).
#UNIFI_USERNAME=
#UNIFI_PASSWORD=
# Option B: API key (Settings -> Control Plane -> Integrations -> Create API Key).
# NOTE: UniFi's Integration API key may not expose IDS/IPS events on all firmware;
# if backfill reports the endpoint isn't accessible, use the local admin above.
#UNIFI_API_KEY=
UNIFI_VERIFY_TLS=false       # gateway uses a self-signed cert; leave false
BACKFILL_MAX=200             # safety cap on number of alerts posted
BACKFILL_POST_DELAY_MS=1200  # delay between Discord posts (avoid rate limits)

# ── Real-time watcher (Mongo polling) ────────────────────────────────────────
# UniFi's syslog forwarding is unreliable on some firmware; the watcher polls the
# UDM's Mongo event store over SSH instead (needs --setup-ssh). Runs inside the
# service automatically when an SSH connection is configured.
WATCH_ENABLED=true
WATCH_POLL_SEC=45            # how often to poll the UDM for new detections
WATCH_LOOKBACK_SEC=600       # on first start with no saved state, look back this far

# ── Web dashboard ────────────────────────────────────────────────────────────
# Local alert dashboard with investigation tools (live packet capture, conntrack,
# surrounding events). Bound to localhost by default — it can run privileged
# commands on the gateway over SSH, so do NOT expose it on the LAN without auth.
WEB_ENABLED=true
WEB_HOST=127.0.0.1
WEB_PORT=8787
WEB_DEFAULT_HOURS=48

# ── NetFlow/IPFIX collector ──────────────────────────────────────────────────
# Makes SecTool a flow collector for true per-flow history in investigations.
# When enabled + SSH is configured, it points the UDM's IPFIX export at this host
# (via the net.netflow.destination sysctl) and re-asserts it every 5 min. Flows
# are collected GOING FORWARD (not retroactive); 1:512 sampling means low-volume
# hosts may not always appear. For persistence across UDM reboots, also set the
# NetFlow Collector Address to this host in the UniFi UI.
NETFLOW_ENABLED=false
NETFLOW_HOST=0.0.0.0
NETFLOW_PORT=2055
NETFLOW_MAX_FLOWS=200000      # in-memory cap
NETFLOW_RETENTION_MIN=720     # drop flows older than this (12h)
NETFLOW_AUTOCONFIGURE_UDM=true
#NETFLOW_ADVERTISE_IP=        # IP to tell the UDM to export to (auto-detected if blank)
NETFLOW_PERSIST=true         # snapshot flows to data/flows.json so history survives restarts
NETFLOW_SAMPLING_RATE=512    # gateway packet-sampling rate (1:N); behavioral baselining scales
                             # sampled byte counts up by this to estimate true volume. Set 1 if unsampled.

# ── IP enrichment (investigation) ────────────────────────────────────────────
# ip-api.com is used automatically (no key). Add keys to enable the others.
# VirusTotal: free key at https://www.virustotal.com/gui/my-apikey (4 req/min).
#VT_API_KEY=
# AbuseIPDB: free key at https://www.abuseipdb.com/account/api (optional).
#ABUSEIPDB_API_KEY=
#IPINFO_TOKEN=
# Auto-enrich every live alert and fold IP intel into the Discord embed; escalate
# severity to critical (firing DISCORD_MENTION) when verdicts cross these thresholds.
ENRICH_AUTO=true
ESCALATE_VT_MALICIOUS=3       # VT malicious+suspicious >= this -> escalate
ESCALATE_ABUSE_SCORE=50       # AbuseIPDB confidence >= this -> escalate

# ── Active response: firewall blocking ───────────────────────────────────────
# "Block this IP" adds it to a SECTOOL_BLOCK ipset + DROP rules on the UDM over
# SSH, re-asserted periodically (UniFi rebuilds chains on provision). Manage
# blocks on the dashboard's "Blocked" page. Private/gateway IPs are always refused.
BLOCK_ENABLED=true
BLOCK_REASSERT_SEC=90
#BLOCK_ALLOWLIST=            # comma-separated public IPs to never block

# ── Scheduled threat digest ──────────────────────────────────────────────────
# Daily Claude-written rollup posted to Discord (top attackers, targeted hosts,
# threat types, totals). Run on demand with: node src/index.ts --digest 24
DIGEST_ENABLED=false
DIGEST_HOUR=8                # local hour (0-23) to post the daily digest
DIGEST_PERIOD_HOURS=24

# ── Threat-intel feeds (proactive blocking + daily changelog) ────────────────
# Fetches public blocklists (abuse.ch, blocklist.de, FireHOL L1, Spamhaus DROP),
# loads them into a SECTOOL_FEED ipset (drops known-bad before they even probe),
# cross-references every enrichment, and posts a highlighted changelog embed to
# Discord every 24h.
INTEL_FEEDS_ENABLED=false
INTEL_BLOCK=true             # false = cross-reference only, don't drop
INTEL_REFRESH_HOURS=24

# ── Autonomous response (auto-block) ─────────────────────────────────────────
# Auto-add IPs to the firewall block when an alert escalates (damning VT/abuse/
# feed verdict) or a source becomes a repeat offender. Guarded by a daily cap and
# the block allowlist. START WITH DRY-RUN (logs "would block" without blocking).
AUTORESPOND_BLOCK_ON_ESCALATION=false
AUTORESPOND_REPEAT_THRESHOLD=0     # 0 = off; e.g. 10 = block after 10 hits/window
AUTORESPOND_REPEAT_WINDOW_HOURS=24
AUTORESPOND_DAILY_CAP=50
AUTORESPOND_DRY_RUN=false          # true = suggest-only (recommended at first)
# Reactive inbound blocking (RECOMMENDED): only blocks a feed-listed IP once it
# initiates INBOUND traffic to you (external->internal, ephemeral source port) and
# you never reached out to it. Cannot break outbound destinations. Safe alternative
# to bulk feed blocking (INTEL_BLOCK). Respects AUTORESPOND_DRY_RUN + DAILY_CAP.
REACTIVE_INBOUND_BLOCK=false
REACTIVE_INBOUND_INTERVAL_SEC=120

# ── Deception (honeypots) ────────────────────────────────────────────────────
# Decoy services on ports nothing legitimate should touch. ANY connection is a
# near-zero-false-positive signal — an external attacker, or (high value) a
# COMPROMISED INTERNAL host scanning your LAN. Hits go to Discord. Ports that are
# already in use (e.g. real RDP on 3389) are skipped automatically.
HONEYPOT_ENABLED=false
HONEYPOT_PORTS=23,2323,21,2222,3389,5900,1433,8081
HONEYPOT_AUTOBLOCK=false      # auto-block EXTERNAL honeypot hitters (never internal)

# ── Behavioral baselining ────────────────────────────────────────────────────
# Learns each internal host's normal outbound behavior, then flags deviations
# (new outbound port, volume spike, fan-out spike) that signatures/feeds miss —
# catches novel malware / exfil / internal scanning. Needs a learning period.
ANOMALY_ENABLED=false
ANOMALY_MIN_LEARN_HOURS=24
ANOMALY_INTERVAL_SEC=300
ANOMALY_VOLUME_SPIKE_FACTOR=8
ANOMALY_ALERT_DISCORD=true

# The conversational analyst (💬 Ask in the dashboard, POST /api/ask) needs no
# config — it uses your Claude auth and queries your telemetry read-only.
#
# Conversational memory: the Ask analyst and the Act agent remember the last few
# turns of each chat session so follow-ups ("block that IP", "now suppress it")
# keep context. Memory is per browser chat, in-process only (never written to
# disk), and reset by the dashboard's "New chat" button.
CONVO_MEMORY_ENABLED=true     # false -> every question starts cold (old behaviour)
CONVO_MEMORY_MAX=10           # messages (user+assistant turns) retained per session
CONVO_MEMORY_TTL_MIN=120      # forget an idle chat session after this many minutes

# ── Runtime ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
DRY_RUN=false                # true -> never POST to Discord, just log

# ── Endpoint agent (process attribution) ─────────────────────────────────────
# Install agent/sectool-agent.mjs on LAN devices to attribute a connection/port
# to the owning program. SecTool queries each device at http://<ip>:AGENT_PORT
# using AGENT_TOKEN (must match the token the agent runs with). LAN hosts only.
AGENT_ENABLED=false
AGENT_PORT=7879
#AGENT_TOKEN=
# Distribution/update server (LAN-bound) that serves the one-liner installer and
# new agent versions. Install on a device: irm http://<this-host>:7878/install.ps1 | iex
AGENT_DIST_PORT=7878
AGENT_DIST_HOST=0.0.0.0
# Allow the dashboard to TERMINATE processes on agent hosts (destructive). This
# is the SecTool-side gate; the agent ALSO requires its own AGENT_ALLOW_KILL=true
# AND a token. Kill refuses on any tokenless agent. Default off.
AGENT_ALLOW_KILL=false

# ── LAN auto-discovery (active device sweep) ─────────────────────────────────
# Discovers every device on the local network from the Devices page (🔍 Scan
# LAN): a TCP-connect ping sweep finds live hosts (even agent-less ones), the OS
# ARP cache attaches MAC + vendor, and NetFlow fills in quiet devices. Only
# RFC1918 subnets the host is directly attached to are ever scanned.
DISCOVERY_ENABLED=true
# Ports probed per host for liveness (open OR refused both prove the host is up).
DISCOVERY_PORTS=22,80,443,445,3389,53,7879
# Per-port connect timeout (ms) and how many hosts to probe concurrently.
DISCOVERY_TIMEOUT_MS=600
DISCOVERY_CONCURRENCY=128
# Hard cap on candidate hosts so a wide netmask (e.g. /16) can't run away.
DISCOVERY_MAX_HOSTS=1024
# Optional explicit subnet(s) to scan instead of auto-detecting (comma-separated
# CIDRs, RFC1918 only), e.g. DISCOVERY_SUBNETS=192.168.1.0/24,10.0.0.0/24
#DISCOVERY_SUBNETS=

# ── Agent push-deploy (install the endpoint agent on discovered devices) ─────
# From the Devices page, push the SecTool agent onto eligible LAN hosts without
# touching them by hand. Requires AGENT_ENABLED=true (so there's an installer to
# download) and ideally AGENT_TOKEN set. RFC1918 IPv4 targets only — never WAN.
# Pushing software onto other machines is sensitive, so this is opt-in.
DEPLOY_ENABLED=false
# SSH transport (Linux/macOS, and Windows hosts running an SSH server). Key auth
# by default (the same .ssh/sectool_udm key SecTool uses, or DEPLOY_SSH_KEY);
# password auth only works if `sshpass` is installed on this host.
DEPLOY_SSH_USER=root
DEPLOY_SSH_PORT=22
#DEPLOY_SSH_KEY=
# WinRM transport — the fallback for Windows hosts that DON'T run SSH. SecTool's
# local PowerShell client (powershell.exe / pwsh) opens a PSRemoting session and
# runs the same /install.ps1 one-liner. The target must have WinRM enabled
# (`Enable-PSRemoting -Force`). WinRM has no key auth, so a password is required
# (entered per-deploy in the UI). Set USE_SSL=true to use HTTPS WinRM on :5986.
DEPLOY_WINRM_ENABLED=true
DEPLOY_WINRM_USER=Administrator
DEPLOY_WINRM_PORT=5985
DEPLOY_WINRM_USE_SSL=false
# How many hosts to deploy to at once, and the per-host install timeout (ms).
DEPLOY_CONCURRENCY=4
DEPLOY_TIMEOUT_MS=120000
# The IP the *target* uses to reach SecTool's dist server. Auto-detected from
# local interfaces (same-subnet preferred) when unset.
#DEPLOY_SERVER_IP=
