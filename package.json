{
  "name": "sectool",
  "version": "1.0.0",
  "description": "Ingests UDM Pro security alerts via syslog, correlates relevant logs, summarizes them with Claude (OAuth), and posts to a Discord webhook.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "self-test": "node src/index.ts --self-test",
    "backfill": "node src/index.ts --backfill 24",
    "setup-ssh": "node src/index.ts --setup-ssh",
    "pull": "node src/index.ts --pull 24",
    "digest": "node src/index.ts --digest 24",
    "compare": "node src/index.ts --compare 24",
    "profile": "node src/index.ts --profile",
    "assets": "node src/index.ts --assets 24",
    "tuning": "node src/index.ts --tuning 168",
    "watchlist": "node src/index.ts --watchlist 24",
    "rhythm": "node src/index.ts --rhythm 168",
    "backlog": "node src/index.ts --backlog 720",
    "novelty": "node src/index.ts --novelty 168",
    "killchain": "node src/index.ts --killchain 168",
    "beacon": "node src/index.ts --beacon 168",
    "efficacy": "node src/index.ts --efficacy 168",
    "spread": "node src/index.ts --spread 168",
    "cooccur": "node src/index.ts --cooccur 168",
    "surge": "node src/index.ts --surge 168",
    "persist": "node src/index.ts --persist 168",
    "iocs": "node src/index.ts --iocs 168 --format plain",
    "print-config": "node src/index.ts --print-config",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "unifi",
    "udm-pro",
    "syslog",
    "ids",
    "ips",
    "suricata",
    "security",
    "claude",
    "discord"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
