{
  "name": "sectool",
  "version": "1.0.0",
  "description": "Ingests UDM Pro security alerts via syslog, correlates relevant logs, summarizes them with Claude (OAuth), and posts to a Discord webhook.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "self-test": "node src/index.ts --self-test",
    "backfill": "node src/index.ts --backfill 24",
    "setup-ssh": "node src/index.ts --setup-ssh",
    "pull": "node src/index.ts --pull 24",
    "digest": "node src/index.ts --digest 24",
    "compare": "node src/index.ts --compare 24",
    "profile": "node src/index.ts --profile",
    "assets": "node src/index.ts --assets 24",
    "tuning": "node src/index.ts --tuning 168",
    "watchlist": "node src/index.ts --watchlist 24",
    "rhythm": "node src/index.ts --rhythm 168",
    "backlog": "node src/index.ts --backlog 720",
    "novelty": "node src/index.ts --novelty 168",
    "killchain": "node src/index.ts --killchain 168",
    "beacon": "node src/index.ts --beacon 168",
    "efficacy": "node src/index.ts --efficacy 168",
    "spread": "node src/index.ts --spread 168",
    "cooccur": "node src/index.ts --cooccur 168",
    "surge": "node src/index.ts --surge 168",
    "persist": "node src/index.ts --persist 168",
    "edges": "node src/index.ts --edges 168",
    "notify": "node src/index.ts --notify 168",
    "classify": "node src/index.ts --classify 168",
    "focus": "node src/index.ts --focus 168",
    "netblocks": "node src/index.ts --netblocks 168",
    "coverage": "node src/index.ts --coverage 168",
    "direction": "node src/index.ts --direction 168",
    "lifecycle": "node src/index.ts --lifecycle 168",
    "risk": "node src/index.ts --risk 168",
    "insight": "node src/index.ts --insight 168",
    "escalation": "node src/index.ts --escalation 168",
    "targets": "node src/index.ts --targets 168",
    "clusters": "node src/index.ts --clusters 168",
    "cve": "node src/index.ts --cve 168",
    "hygiene": "node src/index.ts --hygiene 720",
    "recurrence": "node src/index.ts --recurrence 168",
    "ports": "node src/index.ts --ports 168",
    "scan": "node src/index.ts --scan 168",
    "repertoire": "node src/index.ts --repertoire 168",
    "dwell": "node src/index.ts --dwell 168",
    "mitre": "node src/index.ts --mitre 168",
    "concentration": "node src/index.ts --concentration 168",
    "cohort": "node src/index.ts --cohort 168",
    "suppaudit": "node src/index.ts --suppaudit 168",
    "noise": "node src/index.ts --noise 168",
    "patterns": "node src/index.ts --patterns 168",
    "iocs": "node src/index.ts --iocs 168 --format plain",
    "print-config": "node src/index.ts --print-config",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "unifi",
    "udm-pro",
    "syslog",
    "ids",
    "ips",
    "suricata",
    "security",
    "claude",
    "discord"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
